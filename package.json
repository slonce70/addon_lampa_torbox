{
  "name": "lampa-torbox-enhanced",
  "version": "2.0.0",
  "description": "Enhanced TorBox.app streaming plugin for Lampa media player - онлайн стрімінг торентів",
  "main": "torbox-lampa-plugin.js",
  "scripts": {
    "build": "echo 'Plugin is ready to use'",
    "test": "echo 'No tests specified'",
    "lint": "echo 'No linting configured'"
  },
  "keywords": [
    "lampa",
    "torbox",
    "streaming",
    "torrent",
    "plugin",
    "ukrainian",
    "онлайн",
    "стрімінг",
    "торренти"
  ],
  "author": "Enhanced for Ukrainian community",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/slonce70/addon_lampa_torbox"
  },
  "bugs": {
    "url": "https://github.com/slonce70/addon_lampa_torbox/issues"
  },
  "homepage": "https://github.com/slonce70/addon_lampa_torbox#readme",
  "engines": {
    "node": ">=14.0.0"
  },
  "lampa": {
    "plugin": {
      "name": "TorBox Enhanced",
      "version": "2.0.0",
      "description": "Онлайн стрімінг торентів через TorBox.app",
      "author": "Enhanced Community",
      "type": "source",
      "entry": "torbox-lampa-plugin.js",
      "minLampaVersion": "1.8.0",
      "features": [
        "online-streaming",
        "torrent-support",
        "subtitle-support",
        "auto-episode-detection",
        "quality-selection",
        "caching",
        "retry-logic"
      ],
      "permissions": [
        "network",
        "storage",
        "player"
      ],
      "settings": {
        "apiKey": {
          "type": "string",
          "required": true,
          "description": "TorBox API Key"
        },
        "autoPlay": {
          "type": "boolean",
          "default": true,
          "description": "Auto play first file"
        },
        "autoDelete": {
          "type": "boolean",
          "default": true,
          "description": "Auto delete torrent after viewing"
        },
        "preferredQuality": {
          "type": "select",
          "options": ["480p", "720p", "1080p", "1440p", "2160p"],
          "default": "1080p",
          "description": "Preferred video quality"
        },
        "subtitlesEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable automatic subtitle loading"
        },
        "cacheEnabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable caching for faster access"
        }
      }
    }
  },
  "devDependencies": {},
  "dependencies": {},
  "peerDependencies": {
    "lampa": ">=1.8.0"
  }
}